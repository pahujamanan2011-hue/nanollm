# Makefile for NanoLLM Editor
CC = gcc
CFLAGS = -Wall -Wextra -O2 -std=gnu99 $(shell pkg-config --cflags gtk+-3.0 libcurl)
LDFLAGS = $(shell pkg-config --libs gtk+-3.0 libcurl) -lpthread

TARGET = nanollm_editor

SRCS = main.c cJSON.c config.c chat_history.c network.c api_providers.c gui.c
OBJS = $(SRCS:.c=.o)

PREFIX ?= /usr/local
BINDIR = $(PREFIX)/bin

.PHONY: all clean install uninstall

all: $(TARGET)

$(TARGET): $(OBJS)
	$(CC) $(OBJS) -o $(TARGET) $(LDFLAGS)

# Track headers so changing nanollm.h or cJSON.h triggers a re-compile
%.o: %.c nanollm.h cJSON.h
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f $(OBJS) $(TARGET)

install: $(TARGET)
	install -Dm755 $(TARGET) $(DESTDIR)$(BINDIR)/$(TARGET)

uninstall:
	rm -f $(DESTDIR)$(BINDIR)/$(TARGET)
